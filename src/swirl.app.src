{application, swirl, [
  {description, "High Performance Erlang Stream Processor"},
  {vsn, "0.2.9"},
  {registered, [
    swirl_ets_manager,
    swirl_sup,
    swirl_tracker
  ]},
  {applications, [
    kernel,
    stdlib,
    telemetry,
    uuid
  ]},
  {mod, {swirl, []}},
  {env, []},
  {licenses, ["MIT"]},
  {links, [{"GitHub", "https://github.com/lpgauth/swirl"}]},
  {maintainers, ["Louis-Philippe Gauthier"]}
]}.
